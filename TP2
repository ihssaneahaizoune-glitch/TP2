import numpy as np
import pandas as pd
import matplotlib.pyplot as plt
import seaborn as sns
from sklearn.model_selection import train_test_split
from sklearn.linear_model import LinearRegression
from sklearn.metrics import mean_squared_error, r2_score, mean_absolute_error

# Configuration
plt.style.use('seaborn-v0_8-darkgrid')
sns.set_palette("husl")

print("=" * 60)
print("RÉGRESSION LINÉAIRE - Prédiction de la consommation (MPG)")
print("=" * 60)

# 1. CHARGEMENT DES DONNÉES
print("\n1. Chargement des données...")
column_names = ['MPG', 'Cylinders', 'Displacement', 'Horsepower', 
                'Weight', 'Acceleration', 'Model Year', 'Origin']

df = pd.read_csv('auto-mpg.csv', names=column_names, 
                 na_values="?", comment='\t', sep=" ", skipinitialspace=True)

print(f"   Dimensions : {df.shape}")
print(f"   Colonnes : {df.columns.tolist()}")

# 2. NETTOYAGE
print("\n2. Nettoyage des données...")
print(f"   Valeurs manquantes avant : {df.isnull().sum().sum()}")
df = df.dropna()
print(f"   Valeurs manquantes après : {df.isnull().sum().sum()}")
print(f"   Dimensions après nettoyage : {df.shape}")

# 3. ANALYSE EXPLORATOIRE
print("\n3. Analyse exploratoire...")

# Matrice de corrélation
corr = df.corr()
print("\n   Corrélations avec MPG :")
for col in corr['MPG'].sort_values(ascending=False).index:
    if col != 'MPG':
        print(f"      {col}: {corr.loc['MPG', col]:.3f}")

# Sélection des features (les plus corrélées)
features = ['Weight', 'Displacement', 'Horsepower']
target = 'MPG'

X = df[features]
y = df[target]

print(f"\n   Features sélectionnées : {features}")

# 4. DIVISION DES DONNÉES
print("\n4. Division des données (70% train / 30% test)...")
X_train, X_test, y_train, y_test = train_test_split(X, y, test_size=0.3, random_state=42)
print(f"   Train : {X_train.shape[0]} échantillons")
print(f"   Test : {X_test.shape[0]} échantillons")

# 5. ENTRAÎNEMENT
print("\n5. Entraînement du modèle...")
model = LinearRegression()
model.fit(X_train, y_train)

print(f"   Intercept : {model.intercept_:.4f}")
for f, c in zip(features, model.coef_):
    print(f"   Coefficient {f}: {c:.4f}")

# 6. ÉVALUATION
print("\n6. Évaluation du modèle...")
y_pred = model.predict(X_test)

mse = mean_squared_error(y_test, y_pred)
rmse = np.sqrt(mse)
mae = mean_absolute_error(y_test, y_pred)
r2 = r2_score(y_test, y_pred)

print(f"   R² (Précision) : {r2:.4f} ({r2*100:.2f}%)")
print(f"   RMSE : {rmse:.2f} MPG")
print(f"   MAE : {mae:.2f} MPG")
print(f"   MSE : {mse:.2f}")

# 7. VISUALISATIONS
print("\n7. Génération des graphiques...")

# Figure 1 : Prédictions vs Réel
plt.figure(figsize=(12, 5))

plt.subplot(1, 2, 1)
plt.scatter(y_test, y_pred, alpha=0.6, c='blue', edgecolors='white', linewidth=0.5)
plt.plot([y_test.min(), y_test.max()], [y_test.min(), y_test.max()], 
         'r--', lw=2, label='Prédiction parfaite')
plt.xlabel('Valeurs réelles (MPG)')
plt.ylabel('Prédictions (MPG)')
plt.title('Prédictions vs Valeurs réelles')
plt.legend()
plt.grid(True, alpha=0.3)

# Figure 2 : Résidus
plt.subplot(1, 2, 2)
residuals = y_test - y_pred
plt.scatter(y_pred, residuals, alpha=0.6, c='purple', edgecolors='white', linewidth=0.5)
plt.axhline(y=0, color='red', linestyle='--', lw=2)
plt.xlabel('Prédictions')
plt.ylabel('Résidus')
plt.title('Graphique des résidus')
plt.grid(True, alpha=0.3)

plt.tight_layout()
plt.savefig('regression_lineaire_resultats.png', dpi=150, bbox_inches='tight')
plt.show()

# Figure 3 : Distribution des résidus
plt.figure(figsize=(8, 5))
sns.histplot(residuals, bins=20, kde=True, color='green')
plt.xlabel('Résidus')
plt.ylabel('Fréquence')
plt.title('Distribution des résidus')
plt.axvline(x=0, color='red', linestyle='--')
plt.savefig('residus_distribution.png', dpi=150, bbox_inches='tight')
plt.show()

# 8. PRÉDICTION EXEMPLE
print("\n8. Exemple de prédiction...")
new_car = np.array([[3500, 250, 150]])  # Weight, Displacement, Horsepower
pred = model.predict(new_car)[0]
print(f"   Voiture : Poids=3500lbs, Cylindrée=250, Puissance=150ch")
print(f"   Consommation prédite : {pred:.1f} MPG")

print("\n" + "=" * 60)
print("RÉGRESSION LINÉAIRE - TERMINÉE AVEC SUCCÈS!")
"""
