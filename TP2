import numpy as np
import pandas as pd
import matplotlib.pyplot as plt
import seaborn as sns
from sklearn.model_selection import train_test_split
from sklearn.preprocessing import StandardScaler
from sklearn.linear_model import LogisticRegression
from sklearn.metrics import (accuracy_score, confusion_matrix, 
                           classification_report, roc_curve, auc)

# Configuration
plt.style.use('seaborn-v0_8-darkgrid')
sns.set_palette("husl")

print("=" * 60)
print("RÉGRESSION LOGISTIQUE - Prédiction d'admission universitaire")
print("=" * 60)

# 1. CHARGEMENT DES DONNÉES
print("\n1. Chargement des données...")
df = pd.read_csv('binary.csv')
df.columns = ['admit', 'gre', 'gpa', 'prestige']

print(f"   Dimensions : {df.shape}")
print(f"   Colonnes : {df.columns.tolist()}")
print(f"\n   Distribution des admissions :")
print(f"      Non admis (0) : {(df['admit']==0).sum()} ({df['admit'].mean()*100:.1f}%)")
print(f"      Admis (1) : {(df['admit']==1).sum()} ({(1-df['admit'].mean())*100:.1f}%)")

# 2. STATISTIQUES DESCRIPTIVES
print("\n2. Statistiques par groupe...")
print(df.groupby('admit').agg({
    'gre': ['mean', 'std'],
    'gpa': ['mean', 'std']
}).round(2))

# 3. CRÉATION DES VARIABLES DUMMY
print("\n3. Transformation des variables catégorielles...")
dummy_ranks = pd.get_dummies(df['prestige'], prefix='prestige')
df_encoded = pd.concat([df[['admit', 'gre', 'gpa']], dummy_ranks], axis=1)
print(f"   Nouvelles colonnes : {df_encoded.columns.tolist()}")

# 4. PRÉPARATION DES DONNÉES
print("\n4. Préparation des données...")
X = df_encoded.drop('admit', axis=1)
y = df_encoded['admit']

# Standardisation
scaler = StandardScaler()
X_scaled = X.copy()
X_scaled[['gre', 'gpa']] = scaler.fit_transform(X[['gre', 'gpa']])

print(f"   Features : {X_scaled.shape[1]}")
print(f"   Échantillons : {X_scaled.shape[0]}")

# 5. DIVISION DES DONNÉES
print("\n5. Division des données (70% train / 30% test)...")
X_train, X_test, y_train, y_test = train_test_split(
    X_scaled, y, test_size=0.3, random_state=42, stratify=y
)
print(f"   Train : {X_train.shape[0]} échantillons")
print(f"   Test : {X_test.shape[0]} échantillons")

# 6. ENTRAÎNEMENT
print("\n6. Entraînement du modèle...")
model = LogisticRegression(C=1.0, random_state=42)
model.fit(X_train, y_train)

print(f"   Intercept : {model.intercept_[0]:.4f}")
print("   Coefficients :")
for feat, coef in zip(X.columns, model.coef_[0]):
    print(f"      {feat}: {coef:.4f}")

# 7. ÉVALUATION
print("\n7. Évaluation du modèle...")
y_pred = model.predict(X_test)
y_pred_proba = model.predict_proba(X_test)[:, 1]

# Matrice de confusion
cm = confusion_matrix(y_test, y_pred)
tn, fp, fn, tp = cm.ravel()

accuracy = accuracy_score(y_test, y_pred)
precision = tp / (tp + fp) if (tp + fp) > 0 else 0
recall = tp / (tp + fn) if (tp + fn) > 0 else 0
specificity = tn / (tn + fp) if (tn + fp) > 0 else 0
f1 = 2 * (precision * recall) / (precision + recall) if (precision + recall) > 0 else 0

print(f"\n   Métriques :")
print(f"      Accuracy : {accuracy:.4f} ({accuracy*100:.2f}%)")
print(f"      Precision : {precision:.4f}")
print(f"      Recall/Sensibilité : {recall:.4f}")
print(f"      Spécificité : {specificity:.4f}")
print(f"      F1-Score : {f1:.4f}")

print(f"\n   Matrice de confusion :")
print(f"      Vrais Positifs (TP) : {tp}")
print(f"      Vrais Négatifs (TN) : {tn}")
print(f"      Faux Positifs (FP) : {fp}")
print(f"      Faux Négatifs (FN) : {fn}")

# 8. COURBE ROC
print("\n8. Calcul de la courbe ROC...")
fpr, tpr, thresholds = roc_curve(y_test, y_pred_proba)
roc_auc = auc(fpr, tpr)

print(f"   AUC : {roc_auc:.4f}")
print("   Interprétation : ", end="")
if roc_auc >= 0.9:
    print("Excellent")
elif roc_auc >= 0.8:
    print("Très bon")
elif roc_auc >= 0.7:
    print("Bon")
else:
    print("Acceptable")

# 9. VISUALISATIONS
print("\n9. Génération des graphiques...")

# Figure 1 : Matrice de confusion
plt.figure(figsize=(12, 5))

plt.subplot(1, 2, 1)
sns.heatmap(cm, annot=True, fmt='d', cmap='Blues',
            xticklabels=['Non admis', 'Admis'],
            yticklabels=['Non admis', 'Admis'])
plt.title('Matrice de confusion')
plt.xlabel('Prédiction')
plt.ylabel('Vérité terrain')

# Figure 2 : Courbe ROC
plt.subplot(1, 2, 2)
plt.plot(fpr, tpr, color='darkorange', lw=2, label=f'ROC (AUC = {roc_auc:.3f})')
plt.plot([0, 1], [0, 1], color='navy', lw=2, linestyle='--', label='Aléatoire')
plt.xlim([0.0, 1.0])
plt.ylim([0.0, 1.05])
plt.xlabel('Taux de faux positifs')
plt.ylabel('Taux de vrais positifs')
plt.title('Courbe ROC')
plt.legend(loc="lower right")
plt.grid(True, alpha=0.3)

plt.tight_layout()
plt.savefig('regression_logistique_resultats.png', dpi=150, bbox_inches='tight')
plt.show()

# Figure 3 : Distribution des probabilités
plt.figure(figsize=(8, 5))
plt.hist(y_pred_proba[y_test==0], bins=20, alpha=0.7, label='Non admis', color='red')
plt.hist(y_pred_proba[y_test==1], bins=20, alpha=0.7, label='Admis', color='green')
plt.xlabel('Probabilité d\'admission')
plt.ylabel('Fréquence')
plt.title('Distribution des probabilités prédites')
plt.legend()
plt.savefig('probabilites_distribution.png', dpi=150, bbox_inches='tight')
plt.show()

# 10. OPTIMISATION DU SEUIL
print("\n10. Optimisation du seuil de décision...")
best_threshold = 0.5
best_accuracy = accuracy

for threshold in np.arange(0.3, 0.8, 0.05):
    y_pred_opt = (y_pred_proba >= threshold).astype(int)
    acc_opt = accuracy_score(y_test, y_pred_opt)
    if acc_opt > best_accuracy:
        best_accuracy = acc_opt
        best_threshold = threshold

print(f"   Seuil optimal : {best_threshold:.2f}")
print(f"   Accuracy optimisée : {best_accuracy:.4f} ({best_accuracy*100:.2f}%)")

# 11. PRÉDICTION POUR UN NOUVEL ÉTUDIANT
print("\n11. Exemple de prédiction...")

def predict_admission(gre, gpa, prestige):
    features = np.zeros(6)
    features[0] = gre
    features[1] = gpa
    
    if prestige == 1:
        features[2] = 1
    elif prestige == 2:
        features[3] = 1
    elif prestige == 3:
        features[4] = 1
    elif prestige == 4:
        features[5] = 1
    
    features[0:2] = scaler.transform([features[0:2]])[0]
    proba = model.predict_proba([features])[0][1]
    pred = 1 if proba >= best_threshold else 0
    
    return proba, pred

# Test avec différents profils
test_profiles = [
    (320, 3.8, 1, "Excellent étudiant, meilleur prestige"),
    (300, 3.5, 2, "Bon étudiant, bon prestige"),
    (280, 3.0, 3, "Étudiant moyen, prestige moyen"),
    (260, 2.7, 4, "Étudiant faible, faible prestige"),
]

for gre, gpa, prestige, desc in test_profiles:
    proba, pred = predict_admission(gre, gpa, prestige)
    status = "ADMIS" if pred == 1 else "NON ADMIS"
    print(f"\n   {desc}:")
    print(f"      GRE={gre}, GPA={gpa}, Prestige={prestige}")
    print(f"      → Probabilité: {proba*100:.1f}% - {status}")

print("\n" + "=" * 60)
print("RÉGRESSION LOGISTIQUE - TERMINÉE AVEC SUCCÈS!")
print("=" * 60)
print("=" * 60)
